<resources>

    <!-- Base application theme. -->
    <style name="AppThemeBase" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <!-- colorPrimary is used for the default action bar background -->
        <item name="colorPrimary">@color/primary</item>
        <!-- colorPrimaryDark is used for the status bar -->
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <!-- colorAccent is used as the default value for colorControlActivated
         which is used to tint widgets -->
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/toolbar_foreground</item>
        <!-- You can also set colorControlNormal, colorControlActivated
         colorControlHighlight & colorSwitchThumbNormal. -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowLightStatusBar">@bool/light_status_bar</item>

        <item name="appBarLayoutStyle">@style/AppThemeOverlayAppbarLayoutStyle</item>
        <item name="actionOverflowMenuStyle">@style/Widget.AppCompat.PopupMenu.Overflow</item>
        <item name="tabStyle">@style/Widget.MaterialComponents.TabLayout.PrimarySurface</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.HAcg.MaterialAlertDialog</item>
    </style>

    <style name="AppTheme" parent="AppThemeBase" />

    <style name="AppThemeTranslucent" parent="AppTheme">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <!--<item name="android:windowAnimationStyle">@style/DIY.Animation.SlidingBack</item>-->
        <!--<item name="android:actionBarStyle">@style/DIYActionBar.Custom</item>-->
    </style>

    <style name="AppThemeOverlayAppbarLayoutStyle" parent="Widget.MaterialComponents.AppBarLayout.Primary">
        <item name="materialThemeOverlay">@style/ThemeOverlay.HAcg.AppBar</item>
    </style>

    <style name="ThemeOverlay.HAcg.AppBar" parent="ThemeOverlay.MaterialComponents.Light">
        <item name="android:colorBackground">@color/primary</item>
        <item name="android:popupBackground">@color/primary</item>
        <item name="colorControlNormal">@color/toolbar_foreground</item>
        <item name="colorOnPrimary">@color/toolbar_foreground</item>
        <item name="colorOnSurface">@color/toolbar_foreground</item>
        <item name="colorSurface">@color/primary</item>
        <item name="android:textColorPrimary">@color/toolbar_foreground</item>
        <item name="android:textColorSecondary">@color/toolbar_foreground_muted</item>
    </style>

    <style name="ThemeOverlay.HAcg.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnSurface">@color/text_color_title</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.HAcg.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.HAcg.DialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.HAcg.DialogButton</item>
    </style>

    <style name="Widget.HAcg.DialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
        <item name="iconTint">@color/accent</item>
        <item name="rippleColor">@color/ripple</item>
    </style>
</resources>
